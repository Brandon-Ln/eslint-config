{
  "name": "@brandlen/eslint-config",
  "version": "0.1.0",
  "description": "Personal ESLint flat config for JavaScript and strongly typed TypeScript projects.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "typescript": ">=5.0.0 <6.1.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint/compat": "^1.3.0",
    "@eslint/js": "^9.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.0.0",
    "react": "^19.0.0",
    "@nestjs/common": "^11.0.0"
  }
}
